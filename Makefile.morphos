# Author: Michele Dipace <michele.dipace@kaffeine.net>

CC := System:Development/gg/bin/gcc
CFLAGS := -Wall -Wextra -O2 -noixemul -Iinclude
TARGET := build/telegram-test
SRC := src/main.c core/tg_app.c core/tg_config.c core/tg_log.c core/tg_net.c platforms/morphos/tg_platform_morphos.c

.PHONY: all clean run

all: $(TARGET)

$(TARGET): $(SRC) include/tg_app.h include/tg_config.h include/tg_log.h include/tg_net.h include/tg_platform.h
	$(CC) $(CFLAGS) -o $@ $(SRC)

run: $(TARGET)
	$(TARGET)

clean:
	delete >NIL: $(TARGET)
