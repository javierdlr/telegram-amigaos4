; MorphOS helper for a Telegram HTTPS preflight check.
; Copy this script next to telegram-test and run:
;
;   Execute RunMorphOSPreflight
;
; Or pass an explicit program path:
;
;   Execute RunMorphOSPreflight Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga MorphOS preflight"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --telegram-preflight
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --telegram-preflight
ENDIF
