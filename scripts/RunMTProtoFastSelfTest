; Offline MTProto fast self-test helper.
;
;   Execute RunMTProtoFastSelfTest
;   Execute RunMTProtoFastSelfTest telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga MTProto fast self-test"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --mtproto-self-test-fast
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --mtproto-self-test-fast
ENDIF
