; AROS helper for a Telegram HTTPS preflight check.
; Copy this script next to telegram-test and run:
;
;   Execute RunAROSPreflight
;
; Or pass an explicit program path:
;
;   Execute RunAROSPreflight Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AROS preflight"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --data-dir PROGDIR: --telegram-preflight
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --data-dir PROGDIR: --telegram-preflight
ENDIF
