; Start the user-account MTProto text client with local default files.
;
;   Execute RunMTProtoStart
;   Execute RunMTProtoStart telegram-api.txt telegram-auth.bin phone-code-hash.txt telegram-peers.txt telegram-test

.KEY API,AUTH,CODEHASH,PEERS,PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga"
Echo "Author: Michele Dipace <michele.dipace@kaffeine.net>"
FailAt 21
Stack 262144

; Auth/hash/peers default to the program drawer (relative to the launcher's
; directory), NOT RAM:, so they survive a reboot / ramdisk clear.
IF "{API}" EQ ""
    SET APIFILE "telegram-api.txt"
ELSE
    SET APIFILE "{API}"
ENDIF

IF "{AUTH}" EQ ""
    SET AUTHFILE "telegram-auth.bin"
ELSE
    SET AUTHFILE "{AUTH}"
ENDIF

IF "{CODEHASH}" EQ ""
    SET HASHFILE "phone-code-hash.txt"
ELSE
    SET HASHFILE "{CODEHASH}"
ENDIF

IF "{PEERS}" EQ ""
    SET PEERSFILE "telegram-peers.txt"
ELSE
    SET PEERSFILE "{PEERS}"
ENDIF

IF "{PROGRAM}" EQ ""
    IF EXISTS telegram-test
        Protect telegram-test +e
        telegram-test --mtproto-start-file "$APIFILE" "$AUTHFILE" "$HASHFILE" "$PEERSFILE" <* >*
    ELSE
        Protect RAM:telegram-test +e
        RAM:telegram-test --mtproto-start-file "$APIFILE" "$AUTHFILE" "$HASHFILE" "$PEERSFILE" <* >*
    ENDIF
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --mtproto-start-file "$APIFILE" "$AUTHFILE" "$HASHFILE" "$PEERSFILE" <* >*
ENDIF
