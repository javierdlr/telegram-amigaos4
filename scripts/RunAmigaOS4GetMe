; AmigaOS 4.x helper for a token/getMe smoke test.
; Copy this script next to telegram-test and run:
;
;   Execute RunAmigaOS4GetMe
;
; Or pass an explicit program path:
;
;   Execute RunAmigaOS4GetMe Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AmigaOS 4.x getMe"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --telegram-getme-default
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --telegram-getme-default
ENDIF
