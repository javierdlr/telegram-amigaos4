;
; AROS helper for a token/getMe smoke test.
; Copy this script next to telegram-test and run:
;
;   Execute RunAROSGetMe
;
; Or pass an explicit program path:
;
;   Execute RunAROSGetMe Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AROS getMe"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --data-dir PROGDIR: --telegram-getme-default
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --data-dir PROGDIR: --telegram-getme-default
ENDIF
