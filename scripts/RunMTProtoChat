; Interactive cached-peer MTProto text chat for Amiga shells.
; This can send real Telegram messages after a peer is selected.

.KEY HOST,PORT,DC,API,AUTH,PEERS,PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga"
Echo "Author: Michele Dipace <michele.dipace@kaffeine.net>"
FailAt 21
Stack 65536

IF "{HOST}" EQ ""
    SET TGHOST "149.154.167.91"
ELSE
    SET TGHOST "{HOST}"
ENDIF

IF "{PORT}" EQ ""
    SET TGPORT "443"
ELSE
    SET TGPORT "{PORT}"
ENDIF

IF "{DC}" EQ ""
    SET TGDC "4"
ELSE
    SET TGDC "{DC}"
ENDIF

IF "{API}" EQ ""
    IF EXISTS telegram-api.txt
        SET APIFILE "telegram-api.txt"
    ELSE
        SET APIFILE "RAM:telegram-api.txt"
    ENDIF
ELSE
    SET APIFILE "{API}"
ENDIF

IF "{AUTH}" EQ ""
    IF EXISTS telegram-auth.bin
        SET AUTHFILE "telegram-auth.bin"
    ELSE
        SET AUTHFILE "RAM:telegram-auth.bin"
    ENDIF
ELSE
    SET AUTHFILE "{AUTH}"
ENDIF

IF "{PEERS}" EQ ""
    IF EXISTS telegram-peers.txt
        SET PEERSFILE "telegram-peers.txt"
    ELSE
        SET PEERSFILE "RAM:telegram-peers.txt"
    ENDIF
ELSE
    SET PEERSFILE "{PEERS}"
ENDIF

IF "{PROGRAM}" EQ ""
    IF EXISTS telegram-test
        Protect telegram-test +e
        telegram-test --mtproto-chat-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$PEERSFILE"
    ELSE
        Protect RAM:telegram-test +e
        RAM:telegram-test --mtproto-chat-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$PEERSFILE"
    ENDIF
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --mtproto-chat-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$PEERSFILE"
ENDIF
