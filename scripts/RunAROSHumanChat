; AROS helper for the terse human chat mode.
; Copy this script next to telegram-test and run:
;
;   Execute RunAROSHumanChat
;
; Or pass an explicit program path:
;
;   Execute RunAROSHumanChat Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AROS human chat"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --data-dir PROGDIR: --telegram-human-chat
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --data-dir PROGDIR: --telegram-human-chat
ENDIF
