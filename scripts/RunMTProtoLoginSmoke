;
; Run read-only post-login MTProto checks.
;
;   Execute RunMTProtoLoginSmoke
;   Execute RunMTProtoLoginSmoke 149.154.167.50 443 2 telegram-api.txt telegram-auth.bin 10 telegram-password.txt telegram-test

.KEY HOST,PORT,DC,API,AUTH,LIMIT,PASSWORD,PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga MTProto login smoke"
FailAt 21
Stack 65536

IF "{HOST}" EQ ""
    SET TGHOST "149.154.167.50"
ELSE
    SET TGHOST "{HOST}"
ENDIF

IF "{PORT}" EQ ""
    SET TGPORT "443"
ELSE
    SET TGPORT "{PORT}"
ENDIF

IF "{DC}" EQ ""
    SET TGDC "2"
ELSE
    SET TGDC "{DC}"
ENDIF

IF "{API}" EQ ""
    SET APIFILE "telegram-api.txt"
ELSE
    SET APIFILE "{API}"
ENDIF

IF "{AUTH}" EQ ""
    SET AUTHFILE "telegram-auth.bin"
ELSE
    SET AUTHFILE "{AUTH}"
ENDIF

IF "{LIMIT}" EQ ""
    SET TGLIMIT "10"
ELSE
    SET TGLIMIT "{LIMIT}"
ENDIF

IF "{PASSWORD}" EQ ""
    SET PASSFILE ""
ELSE
    SET PASSFILE "{PASSWORD}"
ENDIF

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    SET TGPROGRAM "telegram-test"
ELSE
    Protect {PROGRAM} +e
    SET TGPROGRAM "{PROGRAM}"
ENDIF

$TGPROGRAM --mtproto-auth-check-local-files "$APIFILE" "$AUTHFILE" "$PASSFILE"
$TGPROGRAM --mtproto-auth-inspect "$AUTHFILE"
$TGPROGRAM --mtproto-auth-status-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC"
$TGPROGRAM --mtproto-auth-get-config-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC"
$TGPROGRAM --mtproto-auth-get-dialogs-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$TGLIMIT"
$TGPROGRAM --mtproto-auth-get-history-self-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$TGLIMIT"
