; AmigaOS 3.x helper for a token/getMe smoke test.
; Copy this script next to telegram-test and run:
;
;   Execute RunAmigaOS3GetMe
;
; Or pass an explicit program path:
;
;   Execute RunAmigaOS3GetMe RAM:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AmigaOS 3.x getMe"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --telegram-getme-default
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --telegram-getme-default
ENDIF
