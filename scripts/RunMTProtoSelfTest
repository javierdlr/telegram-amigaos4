; Offline MTProto self-test helper.
;
;   Execute RunMTProtoSelfTest
;   Execute RunMTProtoSelfTest telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga MTProto self-test"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --mtproto-self-test
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --mtproto-self-test
ENDIF
