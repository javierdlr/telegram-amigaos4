; --- tidy layout: auxiliary files live in data/, avatar photos in avatars/ ---
IF NOT EXISTS data
    Makedir >NIL: data
ENDIF
IF NOT EXISTS avatars
    Makedir >NIL: avatars
ENDIF
IF EXISTS telegram-peers.txt
    Rename >NIL: telegram-peers.txt data/telegram-peers.txt
ENDIF
IF EXISTS telegram-api.txt
    Rename >NIL: telegram-api.txt data/telegram-api.txt
ENDIF
IF EXISTS phone-code-hash.txt
    Rename >NIL: phone-code-hash.txt data/phone-code-hash.txt
ENDIF
IF EXISTS telegram-gui-win.txt
    Rename >NIL: telegram-gui-win.txt data/telegram-gui-win.txt
ENDIF
Rename >NIL: tgav#?.jpg avatars

SET APIFILE "data/telegram-api.txt"
SET AUTHFILE "telegram-auth.bin"
SET HASHFILE "data/phone-code-hash.txt"
SET PEERSFILE "data/telegram-peers.txt"

IF EXISTS telegram-test
    Protect telegram-test +e
    telegram-test --mtproto-start-file "$APIFILE" "$AUTHFILE" "$HASHFILE" "$PEERSFILE" <* >*
ELSE
    Protect RAM:telegram-test +e
    RAM:telegram-test --mtproto-start-file "$APIFILE" "$AUTHFILE" "$HASHFILE" "$PEERSFILE" <* >*
ENDIF

IF WARN
    Echo ""
    Echo "Telegram Amiga (TUI) terminato. Leggi i messaggi qui sopra."
