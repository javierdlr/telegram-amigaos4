;
; Complete MTProto 2FA login with telegram-password.txt.
;
;   Execute RunMTProtoCheckPassword
;   Execute RunMTProtoCheckPassword 149.154.167.50 443 2 telegram-api.txt telegram-auth.bin telegram-password.txt telegram-test

.KEY HOST,PORT,DC,API,AUTH,PASSWORD,PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga MTProto check password"
FailAt 21
Stack 65536

IF "{HOST}" EQ ""
    SET TGHOST "149.154.167.50"
ELSE
    SET TGHOST "{HOST}"
ENDIF

IF "{PORT}" EQ ""
    SET TGPORT "443"
ELSE
    SET TGPORT "{PORT}"
ENDIF

IF "{DC}" EQ ""
    SET TGDC "2"
ELSE
    SET TGDC "{DC}"
ENDIF

IF "{API}" EQ ""
    SET APIFILE "telegram-api.txt"
ELSE
    SET APIFILE "{API}"
ENDIF

IF "{AUTH}" EQ ""
    SET AUTHFILE "telegram-auth.bin"
ELSE
    SET AUTHFILE "{AUTH}"
ENDIF

IF "{PASSWORD}" EQ ""
    SET PASSFILE "telegram-password.txt"
ELSE
    SET PASSFILE "{PASSWORD}"
ENDIF

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --mtproto-auth-check-password-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$PASSFILE"
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --mtproto-auth-check-password-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$PASSFILE"
ENDIF
