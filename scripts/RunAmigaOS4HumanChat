; AmigaOS 4.x helper for the terse human chat mode.
; Copy this script next to telegram-test and run:
;
;   Execute RunAmigaOS4HumanChat
;
; Or pass an explicit program path:
;
;   Execute RunAmigaOS4HumanChat Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AmigaOS 4.x human chat"
FailAt 21
Stack 65536

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --telegram-human-chat
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --telegram-human-chat
ENDIF
