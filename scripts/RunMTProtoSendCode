; Start MTProto login. Requires a phone number argument.
;
;   Execute RunMTProtoSendCode +391234567890
;   Execute RunMTProtoSendCode +391234567890 149.154.167.50 443 2 telegram-api.txt telegram-auth.bin phone-code-hash.txt telegram-test

.KEY PHONE,HOST,PORT,DC,API,AUTH,CODEHASH,PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga MTProto send code"
FailAt 21
Stack 262144

IF "{PHONE}" EQ ""
    Echo "Usage: Execute RunMTProtoSendCode <phone> [host] [port] [dc] [api-file] [auth-file] [code-hash-file] [program]"
    Quit 20
ENDIF

IF "{HOST}" EQ ""
    SET TGHOST "149.154.167.50"
ELSE
    SET TGHOST "{HOST}"
ENDIF

IF "{PORT}" EQ ""
    SET TGPORT "443"
ELSE
    SET TGPORT "{PORT}"
ENDIF

IF "{DC}" EQ ""
    SET TGDC "2"
ELSE
    SET TGDC "{DC}"
ENDIF

IF "{API}" EQ ""
    SET APIFILE "telegram-api.txt"
ELSE
    SET APIFILE "{API}"
ENDIF

IF "{AUTH}" EQ ""
    SET AUTHFILE "telegram-auth.bin"
ELSE
    SET AUTHFILE "{AUTH}"
ENDIF

IF "{CODEHASH}" EQ ""
    SET HASHFILE "phone-code-hash.txt"
ELSE
    SET HASHFILE "{CODEHASH}"
ENDIF

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --mtproto-auth-send-code-file "$TGHOST" "$TGPORT" "$TGDC" "$APIFILE" "{PHONE}" "$AUTHFILE" "$HASHFILE"
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --mtproto-auth-send-code-file "$TGHOST" "$TGPORT" "$TGDC" "$APIFILE" "{PHONE}" "$AUTHFILE" "$HASHFILE"
ENDIF
