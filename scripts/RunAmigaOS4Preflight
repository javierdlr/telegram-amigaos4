; AmigaOS 4.x helper for a Telegram HTTPS preflight check.
; Copy this script next to telegram-test and run:
;
;   Execute RunAmigaOS4Preflight
;
; Or pass an explicit program path:
;
;   Execute RunAmigaOS4Preflight Work:TelegramAmiga/telegram-test

.KEY PROGRAM
.BRA {
.KET }

Echo "Telegram Amiga AmigaOS 4.x preflight"
FailAt 21
Stack 65536
Avail FLUSH

IF "{PROGRAM}" EQ ""
    Protect telegram-test +e
    telegram-test --telegram-preflight
ELSE
    Protect {PROGRAM} +e
    {PROGRAM} --telegram-preflight
ENDIF
