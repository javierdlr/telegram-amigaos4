; MTProto read-only peer cache helper for Amiga shells.
; Copy this script next to telegram-test or run it from the package drawer.

KEY TGHOST/A,TGPORT/A,TGDC/A,APIFILE/A,AUTHFILE/A,TGLIMIT/A,PEERSFILE/A,TGPROGRAM/K

IF "$TGPROGRAM" EQ ""
    SET TGPROGRAM telegram-test
ENDIF

$TGPROGRAM --mtproto-auth-list-peers-file "$TGHOST" "$TGPORT" "$APIFILE" "$AUTHFILE" "$TGDC" "$TGLIMIT" "$PEERSFILE"
