# Host-side cross-build for AROS One i386 alt-abiv0.
# Override TOOLCHAIN and AROS_SDK when they live in different locations.

TOOLCHAIN ?= $(HOME)/amiga-dev/toolchains/aros-i386-abiv0
AROS_SDK ?= /Volumes/AROS One DVD/Development
SDK_GCC_ROOT ?= $(AROS_SDK)/lib/gcc/i386-aros/6.5.0
AROS_CC ?= $(TOOLCHAIN)/i386-aros-gcc
TARGET ?= build/aros-i386-abiv0/telegram-test
BUILD_DIR := $(dir $(TARGET))

SRC := src/main.c core/tg_app.c core/tg_bot.c core/tg_config.c core/tg_console.c core/tg_console_ui.c core/tg_console_tui.c core/tg_gui.c core/tg_gui_window.c core/tg_chat_engine.c core/tg_client_state.c core/tg_offset_state.c core/tg_text_client.c core/tg_file.c core/tg_http.c core/tg_https.c core/tg_json.c core/tg_telegram.c core/tg_log.c core/tg_mtproto.c core/tg_mtproto_auth.c core/tg_mtproto_bigint.c core/tg_mtproto_dc.c core/tg_mtproto_envelope.c core/tg_mtproto_encrypted.c core/tg_mtproto_login.c core/tg_mtproto_message_id.c core/tg_mtproto_probe.c core/tg_mtproto_rsa.c core/tg_mtproto_crypto.c core/tg_mtproto_session.c core/tg_mtproto_srp.c core/tg_mtproto_tl.c core/tg_mtproto_transport.c core/tg_net.c core/tg_tls.c platforms/aros/tg_platform_aros.c

CFLAGS ?= -Wall -Wextra -O2
ENABLE_TLS ?= 0
ENABLE_GZIP ?= 0
ENABLE_GZIP_PUFF ?= 1
CPPFLAGS += -nostdinc \
	-isystem "$(SDK_GCC_ROOT)/include" \
	-isystem "$(SDK_GCC_ROOT)/include-fixed" \
	-I"$(AROS_SDK)/include/aros/posixc" \
	-I"$(AROS_SDK)/include/aros/stdc" \
	-I"$(AROS_SDK)/include" \
	-Iinclude \
	-D__AROS__
LDFLAGS += -nostdlib \
	-L"$(AROS_SDK)/lib" \
	-L"$(SDK_GCC_ROOT)"
LDSTART := "$(AROS_SDK)/lib/startup.o"
LDLIBS += -lautoinit -lcrtprog -lcrt -lstdlib -lstdc.static \
	-lamiga -laros -ldos -lexec -lutility -lgcc -lautoinit

ifeq ($(ENABLE_TLS),1)
CPPFLAGS += -DTG_ENABLE_TLS=1
LDLIBS := -lssl -lcrypto $(LDLIBS)
endif

ifeq ($(ENABLE_GZIP),1)
CPPFLAGS += -DTG_ENABLE_GZIP=1
LDLIBS := -lz $(LDLIBS)
endif

ifeq ($(ENABLE_GZIP_PUFF),1)
CPPFLAGS += -DTG_ENABLE_GZIP_PUFF=1 -Ithird_party/puff
SRC += third_party/puff/puff.c
endif

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(SRC) include/tg_app.h include/tg_bot.h include/tg_config.h include/tg_console.h include/tg_console_ui.h include/tg_console_tui.h include/tg_client_state.h include/tg_offset_state.h include/tg_text_client.h include/tg_file.h include/tg_http.h include/tg_https.h include/tg_json.h include/tg_telegram.h include/tg_log.h include/tg_mtproto.h include/tg_mtproto_auth.h include/tg_mtproto_bigint.h include/tg_mtproto_dc.h include/tg_mtproto_envelope.h include/tg_mtproto_encrypted.h include/tg_mtproto_login.h include/tg_mtproto_message_id.h include/tg_mtproto_probe.h include/tg_mtproto_rsa.h include/tg_mtproto_crypto.h include/tg_mtproto_session.h include/tg_mtproto_srp.h include/tg_mtproto_tl.h include/tg_mtproto_transport.h include/tg_net.h include/tg_platform.h include/tg_tls.h third_party/puff/puff.h
	mkdir -p "$(BUILD_DIR)"
	$(AROS_CC) $(CPPFLAGS) $(CFLAGS) $(LDFLAGS) $(LDSTART) $(SRC) $(LDLIBS) -o "$@"

clean:
	rm -f "$(TARGET)"
