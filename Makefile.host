# SPDX-License-Identifier: MIT
#
# Host build (macOS / Linux) for CI and local testing of the portable
# layers: the AROS platform file carries complete POSIX #else branches
# (select, termios, /dev/urandom), so the same sources compile into a
# native binary whose TL / crypto / JSON self-tests run with no Amiga
# in sight. Not a supported end-user target.

CC ?= cc
TARGET ?= build/host/telegram-test
BUILD_DIR := $(dir $(TARGET))

SRC := src/main.c core/tg_app.c core/tg_bot.c core/tg_config.c core/tg_console.c core/tg_console_ui.c core/tg_console_tui.c core/tg_gui.c core/tg_gui_window.c core/tg_chat_engine.c core/tg_gui_driver.c core/tg_client_state.c core/tg_offset_state.c core/tg_text_client.c core/tg_file.c core/tg_http.c core/tg_https.c core/tg_json.c core/tg_telegram.c core/tg_log.c core/tg_mtproto.c core/tg_mtproto_auth.c core/tg_mtproto_bigint.c core/tg_mtproto_dc.c core/tg_mtproto_envelope.c core/tg_mtproto_encrypted.c core/tg_mtproto_login.c core/tg_mtproto_message_id.c core/tg_mtproto_probe.c core/tg_mtproto_rsa.c core/tg_mtproto_crypto.c core/tg_mtproto_session.c core/tg_mtproto_srp.c core/tg_mtproto_tl.c core/tg_mtproto_transport.c core/tg_net.c core/tg_tls.c platforms/aros/tg_platform_aros.c

CFLAGS ?= -Wall -Wextra -O2
ENABLE_GZIP_PUFF ?= 1
CPPFLAGS += -Iinclude -DTG_ENABLE_TLS=0
ifeq ($(ENABLE_GZIP_PUFF),1)
CPPFLAGS += -DTG_ENABLE_GZIP_PUFF=1 -Ithird_party/puff
SRC += third_party/puff/puff.c
endif

all: $(TARGET)

$(TARGET): $(SRC)
	mkdir -p "$(BUILD_DIR)"
	$(CC) $(CFLAGS) $(CPPFLAGS) -o "$(TARGET)" $(SRC)

clean:
	rm -f "$(TARGET)"

.PHONY: all clean
